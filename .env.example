# Database (Docker Compose sets this automatically; override for external PG)
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Auth
SECRET_KEY=change-me-in-production-use-a-long-random-string

# PostgreSQL (used by Docker Compose)
POSTGRES_USER=progility
POSTGRES_PASSWORD=progility
POSTGRES_DB=mbc_automation

# Anthropic
ANTHROPIC_API_KEY=

# fal.ai
FAL_KEY=

# Google Drive (optional)
GOOGLE_APPLICATION_CREDENTIALS=
MBC_DRIVE_OUTPUT_FOLDER_ID=
MC_DRIVE_OUTPUT_FOLDER_ID=

# Gmail (optional)
GMAIL_SENDER=
JUSTINE_EMAIL=

# Pipeline
TEST_MODE=false    # Set true to use placeholder images instead of fal.ai
